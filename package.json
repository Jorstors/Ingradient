{
  "name": "ingradient",
  "version": "1.0.0",
  "description": "A Recipe Search Engine.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development --hot",
    "dist": "electron-builder"
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react"
    ]
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3": "^5.1.7",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.7",
    "@babel/preset-env": "^7.25.7",
    "@babel/preset-react": "^7.25.7",
    "babel-loader": "^9.2.1",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.7",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jorstors/Ingradient.git"
  },
  "author": "Justus Jones",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Jorstors/Ingradient/issues"
  },
  "homepage": "https://github.com/Jorstors/Ingradient#readme",
  "build": {
    "appId": "com.ingradient.electronreact",
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
